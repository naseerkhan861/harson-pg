{
  "name": "harson-platform",
  "version": "1.0.0",
  "description": "HARSON Platform",
  "main": "desktop/main.js",
  "author": "CLBase",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "desktop": "electron .",
    "release:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.clbase.harsonplatform",
    "productName": "HARSON Platform",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "server.js",
      "db.js",
      "package.json",
      "package-lock.json",
      "src/**/*",
      "public/**/*",
      "data/**/*",
      "scripts/**/*",
      "desktop/**/*",
      ".env.example"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HARSON Platform"
    }
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "nanoid": "^3.3.12"
  }
}
