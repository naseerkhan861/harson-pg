{
  "name": "harson-project",
  "version": "1.0.0-beta.1",
  "description": "HARSON modular MVVM Node application with secure CSV account storage",
  "main": "electron-main.js",
  "scripts": {
    "setup": "node -e \"const fs=require('fs'); const files=[['data/users.example.csv','data/users.csv']]; for (const [src,dst] of files) { if (fs.existsSync(src) && !fs.existsSync(dst)) fs.copyFileSync(src,dst); }\"",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "seed:admin": "node scripts/seedAdmin.js",
    "dist": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.3",
    "nanoid": "^3.3.7"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.harson.clbase.beta",
    "productName": "HARSON CL_Base Platform Beta",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "package.json",
      "package-lock.json",
      "public/**/*",
      "src/**/*",
      "data/**/*",
      "scripts/**/*",
      ".env.example"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HARSON CL_Base Beta"
    }
  }
}